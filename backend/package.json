{
  "name": "jsh-dashboard-backend",
  "version": "2.0.0",
  "description": "JSH Dashboard API — Hono + Node.js 22 + DuckDB + engine",
  "type": "module",
  "scripts": {
    "dev":          "tsx watch src/app.ts",
    "start":        "node dist/app.js",
    "build":        "tsc",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "test:coverage": "vitest run --coverage",
    "lint":         "eslint src --ext .ts"
  },
  "dependencies": {
    "hono":                    "^4.5.3",
    "@hono/node-server":       "^1.13.1",
    "@hono/node-ws":           "^1.0.3",
    "@duckdb/node-api":        "^1.1.3",
    "ioredis":                 "^5.4.1",
    "pg":                      "^8.13.0",
    "papaparse":               "^5.4.1",
    "xlsx":                    "^0.18.5",
    "yaml":                    "^2.5.1",
    "multer":                  "^1.4.5-lts.1",
    "file-type":               "^19.5.0",
    "archiver":                "^7.0.1",
    "zod":                     "^3.23.8",
    "date-fns":                "^3.6.0"
  },
  "devDependencies": {
    "typescript":              "^5.5.4",
    "tsx":                     "^4.19.1",
    "@types/node":             "^22.5.5",
    "@types/pg":               "^8.11.10",
    "@types/multer":           "^1.4.12",
    "@types/papaparse":        "^5.3.14",
    "vitest":                  "^2.1.1",
    "@vitest/coverage-v8":     "^2.1.1",
    "eslint":                  "^9.10.0"
  }
}
