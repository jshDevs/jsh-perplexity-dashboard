{
    "name": "jsh/dashboard",
    "description": "JSH Dashboard — Sistema de dashboards din\u00e1micos auto-generados",
    "keywords": ["dashboard", "analytics", "laravel", "duckdb"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "predis/predis": "^2.2",
        "phpoffice/phpspreadsheet": "^2.3",
        "greenlion/php-sql-parser": "^4.3",
        "symfony/yaml": "^7.0",
        "satur-io/duckdb-php": "^0.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "test": "php artisan test",
        "lint": "./vendor/bin/pint"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
