# JSH Dashboard — variables de entorno
# Copiar a .env y ajustar antes de docker compose up

# ── Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── PostgreSQL
POSTGRES_USER=jsh
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=jsh_dashboard

# ── Redis
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD
REDIS_MAXMEMORY=512mb

# ── Backend
JWT_SECRET=CAMBIAR_JWT_SECRET_MIN_32_CHARS
MAX_UPLOAD_BYTES=52428800
MAX_UPLOAD_MB=50
DATASET_TTL_SEC=86400
MAX_DATASET_ROWS=100000
