APP_NAME="JSH Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=dashboard_db
DB_USERNAME=dashboard
DB_PASSWORD=secret

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=dashboard-app
REVERB_APP_KEY=jsh-reverb-key
REVERB_APP_SECRET=jsh-reverb-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# DuckDB
DUCKDB_MODE=ffi          # ffi | cli | sidecar
DUCKDB_CLI_PATH=/usr/local/bin/duckdb
DUCKDB_MAX_MEMORY=1GB
DUCKDB_THREADS=4

# Security
MAX_UPLOAD_SIZE_MB=50
QUERY_TIMEOUT_SECONDS=30
QUERY_RATE_LIMIT=10
