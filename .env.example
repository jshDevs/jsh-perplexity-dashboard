# Application
APP_ENV=production
APP_KEY=base64:run_php_artisan_key_generate_here
APP_DEBUG=false
APP_PORT=80

# Database
DB_DATABASE=jsh_dashboard
DB_USERNAME=jsh
DB_PASSWORD=change_me_in_production

# DuckDB
DUCKDB_MODE=cli
DUCKDB_MAX_MEMORY=1GB
DUCKDB_THREADS=4

# Laravel Reverb (WebSocket)
REVERB_APP_ID=jsh_app
REVERB_APP_KEY=jsh_key_change_me
REVERB_APP_SECRET=jsh_secret_change_me
